{
"dataRoles": [
        { "displayName": "Valor Inicial","displayNameKey": "Visual_ValorInicial", "name": "startValue", "kind": "Measure" },
        { "displayName": "Categorías","displayNameKey": "Visual_bridgeCategory", "name": "bridgeCategory", "kind": "Grouping"  },
        { "displayName": "Valores","displayNameKey": "Visual_bridgeMeasures", "name": "bridgeMeasure", "kind": "GroupingOrMeasure" },
        { "displayName": "Valor Final","displayNameKey": "Visual_ValorFinal", "name": "endValue", "kind": "Measure" }
    ],
    "dataViewMappings": [{
        "categorical": {
            "categories": { "for": { "in": "bridgeCategory" } },
            "values": {
                "select": [
                    { "bind": { "to": "startValue" } },
                    { "bind": { "to": "bridgeMeasure" } },
                    { "bind": { "to": "endValue" } }
                ]
            }
        },
    
        "conditions": [
            { "startValue": { "max": 1 }, "endValue": { "max": 1 } },
            { "bridgeCategory": { "min": 0 }, "bridgeMeasure": { "min": 1 } }
        ]
    }],
    "objects": {
        "colors": {
            "displayName": "Colores",
            "displayNameKey": "SettingsCat_Colors",
            "properties": {
                "totalColor": {
                    "displayName": "Total Color",
                    "displayNameKey": "Settings_TotalColor",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "increaseColor": {
                    "displayName": "Increase Color",
                    "displayNameKey": "Settings_increaseColor",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "decreaseColor": {
                    "displayName": "Decrease Color",
                    "displayNameKey": "Settings_decreaseColor",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "connectorColor": {
                    "displayName": "Connector Color",
                    "displayNameKey": "Settings_connectorColor",
                    "type": { "fill": { "solid": { "color": true } } }
                }
            }
        },
        "axis":{
            "displayName": "Axis",
            "displayNameKey": "SettingsCat_Axis",
            "properties": {
                 "showXAxis": {
                    "displayName": "Show X Axis",
                    "displayNameKey": "Settings_ShowXAxis",

                    "type": { "bool": true }
                },
                "showYAxis": {
                    "displayName": "Show Y Axis",
                    "displayNameKey": "Settings_ShowYAxis",

                    "type": { "bool": true }
                },
                "AxisYColor": {
                    "displayName": "Axis color",
                    "displayNameKey": "Settings_AxisColor",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "fontFamily": {
                    "displayName": "Font family",
                    "displayNameKey": "Settings_fontFamily",
                    "type": { "text": true }
                },
                "fontSize": {
                    "displayName": "Font Size",
                    "displayNameKey": "Settings_fontSize",
                    "type": { "numeric": true }
                },
                "FontYAxisColor": {
                    "displayName": "Axis labels color",
                    "displayNameKey": "Settings_axislabelsColor",
                    "type": { "fill": { "solid": { "color": true } } }
                }
                }
            },
        "AlignmentCard2": {
            "displayName": "Alingment Labels",
            "displayNameKey": "Settings_AligmentCard",
            "properties": {
                "labelRotation": {
                    "displayName": "Label rotation",
                    "displayNameKey": "Settings_rotation",
                    "type": { "numeric": true }
                },
                "dYAdjustment": {
                    "displayName": "Ajuste vertical de etiquetas",
                    "displayNameKey": "Settings_dYAdjustment",
                    "type": { "numeric": true }
                },
                "hasOthers":{
                    "displayName": "Others category",
                    "displayNameKey": "Settings_hasOthers",
                    "type": { "bool": true }
                }, 
                "OthersLabel":{
                    "displayName": "Others label",
                    "displayNameKey": "Settings_OthersLabel",
                    "type": { "text": true }
                }, 
                "hasAligment":{
                    "displayName": "End Aligment",
                    "displayNameKey": "Settings_hasAligment",
                    "type": { "bool": true }
                }, 
                "startlevel": {
                    "displayName": "Start Level",
                    "displayNameKey": "Settings_startlevel",
                    "type": { "numeric": true }
                },
                "hasConnections":{
                    "displayName": "Connectors",
                    "displayNameKey": "Settings_hasConnections",
                    "type": { "bool": true }
                }
            }
        }
    },
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        },
        "roles": [
            "tooltips"
        ]
    },
    "supportsMultiVisualSelection": true,
    "supportsLandingPage": true,
    "supportsEmptyDataView": true,
    "privileges": []
}
