{
"dataRoles": [
        { "displayName": "Valor Inicial", "name": "startValue", "kind": "Measure" },
        { "displayName": "Categorías del Puente", "name": "bridgeCategory", "kind": "Grouping"  },
        { "displayName": "Variaciones (Valores)", "name": "bridgeMeasure", "kind": "GroupingOrMeasure" },
        { "displayName": "Valor Final", "name": "endValue", "kind": "Measure" }
    ],
    "dataViewMappings": [{
        "categorical": {
            "categories": { "for": { "in": "bridgeCategory" } },
            "values": {
                "select": [
                    { "bind": { "to": "startValue" } },
                    { "bind": { "to": "bridgeMeasure" } },
                    { "bind": { "to": "endValue" } }
                ]
            }
        },
    
        "conditions": [
            { "startValue": { "max": 1 }, "endValue": { "max": 1 } },
            { "bridgeCategory": { "min": 0 }, "bridgeMeasure": { "min": 1 } }
        ]
    }],
    "objects": {
        "colors": {
            "displayName": "Colores",
            "properties": {
                "totalColor": {
                    "displayName": "Color Totales",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "increaseColor": {
                    "displayName": "Color Incrementos",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "decreaseColor": {
                    "displayName": "Color Decrementos",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "connectorColor": {
                    "displayName": "Color Conectores",
                    "type": { "fill": { "solid": { "color": true } } }
                }
            }
        },
        "labels": {
            "displayName": "Etiquetas",
            "properties": {
                "inicioText": {
                    "displayName": "Texto de inicio",
                    "type": { "text": true }
                },
                "finText": {
                    "displayName": "Texto de fin",
                    "type": { "text": true }
                }
            }
        },
        "axis":{
            "displayName": "Axis",
            "properties": {
                 "showXAxis": {
                    "displayName": "Show X Axis",
                    "type": { "bool": true }
                },
                "showYAxis": {
                    "displayName": "Show Y",
                    "type": { "bool": true }
                },
                "AxisYColor": {
                    "displayName": "Color del eje Y",
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "fontFamily": {
                    "displayName": "Fuente del eje Y",
                    "type": { "text": true }
                },
                "fontSize": {
                    "displayName": "Tamaño de fuente del eje Y",
                    "type": { "numeric": true }
                },
                "FontYAxisColor": {
                    "displayName": "Color de fuente del eje Y",
                    "type": { "fill": { "solid": { "color": true } } }
                }
                }
            },
        "AlignmentCard2": {
            "displayName": "Alineación de etiquetas",
            "properties": {
                "labelRotation": {
                    "displayName": "Rotación de etiquetas",
                    "type": { "numeric": true }
                },
                "dYAdjustment": {
                    "displayName": "Ajuste vertical de etiquetas",
                    "type": { "numeric": true }
                }
            }
        }
    },
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        },
        "roles": [
            "tooltips"
        ]
    },
    "supportsMultiVisualSelection": true,
    "supportsLandingPage": true,
    "supportsEmptyDataView": true,
    "privileges": []
}
